# ─── TJU 凭据（自用） ───────────────────────────────────────
# tju 库用这两个变量登录 SSO + EAMS。Next.js 会把它们传给 Python 子进程。
# 真实查询需处于校园网或 VPN 环境。
TJU_USER="your_student_id"
TJU_PASS="your_password"

# Python 解释器路径（默认项目内 venv，运行 `pnpm py:setup` 创建）
TJU_PYTHON=".venv/bin/python"

# ─── Anthropic（课表截图识别，可选） ───────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# 模型：claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL="claude-opus-4-8"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
