# ─── TJU Credentials ────────────────────────────────────────────────────────
# Two options — pick one:
#
#  A) Set credentials directly (used by the tju library to log in via SSO + EAMS):
TJU_USER="your_student_id"
TJU_PASS="your_password"
#
#  B) Or point to an existing .env file that already contains TJU_USER/TJU_PASS.
#     The file is read at runtime; credentials are never copied into this repo.
#     (Comment out A and uncomment B when using this approach.)
# TJU_ENV_FILE="/data/workspace/tju-python/.env"

# Python interpreter with the `tju` library installed.
# Can be the tju-python project's own venv (no re-install needed):
#   TJU_PYTHON="/data/workspace/tju-python/.venv/bin/python"
# Or the venv created by this project (via `pnpm py:setup`):
TJU_PYTHON=".venv/bin/python"

# ─── Anthropic (schedule screenshot OCR, optional) ───────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Demo / Vercel mode ──────────────────────────────────────────────────────
# Set to "0" locally to simulate read-only demo mode (no live campus fetches):
# TJU_LIVE="0"
