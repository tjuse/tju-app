# ─── Database ───────────────────────────────────────────────
# Vercel Postgres (Neon) connection string, or local docker Postgres
DATABASE_URL="postgresql://tju_user:tju_pass@localhost:5432/tju_app?schema=public"

# ─── Auth.js (NextAuth v5) ──────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace_me_with_32_byte_hex_secret"
# Optional: restrict to your TJU email during development
# AUTH_ALLOWED_EMAIL="your@tju.edu.cn"

# ─── Anthropic (course screenshot OCR) ─────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Model to use for OCR. Defaults to claude-opus-4-8 (vision capable).
# Options: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL="claude-opus-4-8"

# ─── Phase 2: Credential Encryption ────────────────────────
# AES-GCM 256-bit key for encrypting TJU campus credentials at rest.
# Generate with: openssl rand -hex 32
# NEVER commit the real key. Only used in Phase 2.
# CREDENTIAL_ENC_KEY="replace_me_with_32_byte_hex_key"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
