# ─── TJU 凭据（自用） ───────────────────────────────────────
# 两种方式二选一：
#  A) 直接在此填写（tju 库用它登录 SSO + EAMS）
TJU_USER="your_student_id"
TJU_PASS="your_password"
#  B) 或指向一个已有 .env 文件，运行时只读取其中的 TJU_USER/TJU_PASS
#     （凭据不会复制进本仓库）。设置后可留空上面的 A。
# TJU_ENV_FILE="/data/workspace/tju-python/.env"

# Python 解释器路径。可指向已安装 tju 的环境，例如 tju-python 的 venv：
#   TJU_PYTHON="/data/workspace/tju-python/.venv/bin/python"
# 或本项目自建 venv（pnpm py:setup）：
TJU_PYTHON=".venv/bin/python"

# ─── Anthropic（课表截图识别，可选） ───────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
