{
  "manifest_version": 3,
  "name": "TJU App Bridge",
  "version": "0.1.4",
  "description": "Fetches private TJU EAMS data (schedule/grades/exams) from your campus session and shares it with tju-app.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.tju.edu.cn/*", "https://sso.tju.edu.cn/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tju.app/*",
        "https://*.tju.app/*",
        "https://tjuse.netlify.app/*",
        "https://*.netlify.app/*",
        "https://*.vercel.app/*",
        "http://localhost:*/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TJU App Bridge"
  }
}
