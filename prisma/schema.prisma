// Prisma schema — tju.app
// 设计原则：预留多用户能力，MVP 可只有单条 User 记录。
// Phase 2 的校内凭据字段已预留，密钥来自 env，绝不存明文。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 用户 ───────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  credential  Credential?
  courses     Course[]
  links       Link[]
  sessions    Session[]
  accounts    Account[]

  @@map("users")
}

// ─── Auth.js (NextAuth v5) tables ───────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Phase 2：TJU 校内凭据（加密存储） ──────────────────────────
// AES-GCM 加密，密钥来自 env CREDENTIAL_ENC_KEY，永不存明文。
// Phase 1 不使用此表，但提前建好结构。
model Credential {
  id           String   @id @default(cuid())
  userId       String   @unique
  encStudentId String   // AES-GCM ciphertext (base64)
  encPassword  String   // AES-GCM ciphertext (base64)
  // 可选：存储短期 CAS session ticket，减少登录频次
  casSession   String?  @db.Text
  casExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credentials")
}

// ─── 课程表 ──────────────────────────────────────────────────────
// MVP：手动录入 / ICS 导入 / 截图 AI 解析（source = manual|ics|ocr）
// Phase 2：source = sync（CAS 自动抓取）
model Course {
  id       String  @id @default(cuid())
  userId   String
  name     String
  teacher  String?
  location String?
  weekday  Int     // 1=周一 … 7=周日
  startSlot Int   // 第几节课开始（1-based）
  endSlot   Int   // 第几节课结束（含）
  weeks    Int[]  // 上课的周次列表，如 [1,2,3,...,16]
  color    String? // hex，可选自定义颜色
  source   String  @default("manual") // manual | ics | ocr | sync
  semester String? // 如 "2025-2026-2"，便于按学期筛选
  note     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekday])
  @@index([userId, semester])
  @@map("courses")
}

// ─── 常用链接 ─────────────────────────────────────────────────────
// 内置默认链接（userId = null）+ 用户自定义（userId 非空）
model Link {
  id       String  @id @default(cuid())
  userId   String?
  title    String
  url      String
  icon     String? // URL 或 lucide 图标名
  category String? // 如 "教务"、"生活"、"工具"
  order    Int     @default(0)
  isBuiltIn Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@map("links")
}

