{
  "name": "tju-app",
  "version": "0.1.4",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "py:setup": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "tju:schedule": ".venv/bin/python scripts/tju_cli.py schedule",
    "tju:courses": ".venv/bin/python scripts/tju_cli.py courses"
  },
  "dependencies": {
    "@tju-app/eams-parsers": "workspace:*",
